---
import '../styles/global.css';
import { SITE_INFO } from '../data/site-info';

interface Props { title?: string; description?: string; }
const {
  title = `Sanguchon | Sanguchería, completos y hamburguesas`,
  description = SITE_INFO.description,
} = Astro.props;

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Restaurant",
      "@id": `${SITE_INFO.url}/#restaurant`,
      name: SITE_INFO.name,
      alternateName: "Sanguchon",
      description: SITE_INFO.description,
      url: SITE_INFO.url,
      logo: `${SITE_INFO.url}/favicon.svg`,
      image: `${SITE_INFO.url}${SITE_INFO.ogImage}`,
      telephone: SITE_INFO.phone,
      email: SITE_INFO.email,
      priceRange: "$$",
      servesCuisine: ["Sanguchería", "Completos", "Sánguches", "Hamburguesas", "Comida rápida"],
      menu: `${SITE_INFO.url}${SITE_INFO.menuUrl}`,
      sameAs: [SITE_INFO.instagramUrl],
      address: {
        "@type": "PostalAddress",
        streetAddress: SITE_INFO.streetAddress,
        postalCode: SITE_INFO.postalCode,
        addressLocality: SITE_INFO.addressLocality,
        addressRegion: SITE_INFO.addressRegion,
        addressCountry: SITE_INFO.addressCountry,
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: SITE_INFO.latitude,
        longitude: SITE_INFO.longitude,
      },
      hasMap: SITE_INFO.googleMapsUrl,
      openingHoursSpecification: [
        { "@type": "OpeningHoursSpecification", dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Sunday"], opens: "12:30", closes: "23:15" },
        { "@type": "OpeningHoursSpecification", dayOfWeek: ["Friday", "Saturday"], opens: "12:30", closes: "23:59" },
      ],
    },
    {
      "@type": "WebSite",
      "@id": `${SITE_INFO.url}/#website`,
      url: SITE_INFO.url,
      name: SITE_INFO.name,
      alternateName: "Sanguchon",
      inLanguage: "es-CL",
      publisher: { "@id": `${SITE_INFO.url}/#restaurant` },
    },
  ],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#100d0b" />
    <meta name="color-scheme" content="dark" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={SITE_INFO.url} />
    <!-- Explicit 16px favicon plus ICO/SVG fallbacks for broad compatibility. -->
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE_INFO.url} />
    <meta property="og:site_name" content="Sanguchon" />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:image" content={`${SITE_INFO.url}${SITE_INFO.ogImage}`} />
    <meta property="og:image:alt" content="Sanguchon, sanguchería a la parrilla en San Miguel" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE_INFO.url}${SITE_INFO.ogImage}`} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- Dark-only brand: set before paint to avoid any light-theme flash. -->
    <script is:inline>
      (() => {
        document.documentElement.dataset.theme = 'dark';
      })();
    </script>

    <script is:inline>
      (() => {
        if ('scrollRestoration' in history) {
          history.scrollRestoration = 'manual';
        }

        const navigationEntry = performance.getEntriesByType('navigation')[0];
        const isReload =
          navigationEntry?.type === 'reload' ||
          performance.navigation?.type === 1;

        const resetToTop = () => {
          if (window.location.hash) {
            history.replaceState(null, '', `${window.location.pathname}${window.location.search}`);
          }

          document.documentElement.scrollTop = 0;
          document.body.scrollTop = 0;
          window.scrollTo({ top: 0, left: 0, behavior: 'auto' });
        };

        const runReset = () => {
          requestAnimationFrame(() => {
            resetToTop();
            requestAnimationFrame(resetToTop);
          });
        };

        if (isReload) {
          runReset();
        }

        window.addEventListener('load', runReset, { once: true });
        window.addEventListener('pageshow', (event) => {
          if (event.persisted || isReload) {
            runReset();
          }
        });
      })();
    </script>
  </head>
  <body>
    <div class="noise pointer-events-none fixed inset-0 z-[90] opacity-[0.025] mix-blend-soft-light" aria-hidden="true"></div>
    <slot />
  </body>
</html>
