---
import logoSanGuchon from "../assets/logo-san-guchon.svg";
---

<div
  class="splash"
  id="siteSplash"
  role="status"
  aria-label="Encendiendo la parrilla de San Guchon"
>
  <div class="splash__embers" aria-hidden="true"></div>
  <div class="splash__halo" aria-hidden="true"></div>
  <div class="splash__scanline" aria-hidden="true"></div>
  <div class="splash__flare" aria-hidden="true"></div>

  <div class="splash__content">
    <div class="splash__logo-shell">
      <span class="splash__ring" aria-hidden="true"></span>
      <img
        src={logoSanGuchon.src}
        width="1000"
        height="900"
        alt="San Guchon"
        class="splash__logo"
      />
    </div>
    <p class="splash__eyebrow">Fuego real · San Miguel</p>
    <div class="splash__progress" aria-hidden="true"><span></span></div>
    <p class="splash__kicker">Sanguchon / Est. 2026</p>
  </div>
</div>

<style>
  .splash {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    place-items: center;
    overflow: hidden;
    background:
      radial-gradient(circle at 50% 58%, rgb(96 22 4 / 0.48), transparent 34%),
      linear-gradient(145deg, #080604, #160c08 52%, #090605);
    color: #fff8ed;
    isolation: isolate;
    transition:
      opacity 0.65s cubic-bezier(0.4, 0, 0.2, 1),
      visibility 0.65s step-end;
  }

  .splash[hidden] {
    display: none;
  }
  .splash.is-leaving {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .splash__embers {
    position: absolute;
    inset: 0;
    opacity: 0.32;
    background-image:
      radial-gradient(circle, #ffb02e 0 1px, transparent 1.8px),
      radial-gradient(circle, #e83b16 0 1px, transparent 1.7px);
    background-position:
      0 0,
      28px 32px;
    background-size:
      64px 72px,
      92px 88px;
    mask-image: linear-gradient(to top, #000, transparent 72%);
    animation: embers-rise 3.2s linear infinite;
  }

  .splash__halo {
    position: absolute;
    width: min(68vw, 560px);
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgb(255 81 19 / 0.25),
      rgb(232 59 22 / 0.08) 42%,
      transparent 68%
    );
    filter: blur(14px);
    animation:
      grill-ignite 1.8s 0.25s ease-out both,
      halo-pulse 1.6s 1.1s ease-in-out infinite;
  }

  .splash__scanline {
    position: absolute;
    inset: 0;
    opacity: .12;
    background: repeating-linear-gradient(0deg, transparent 0 3px, rgb(255 248 237 / .12) 4px, transparent 5px);
    mix-blend-mode: overlay;
    animation: scan-drift 2.8s linear infinite;
  }

  .splash__flare {
    position: absolute;
    left: 50%;
    top: 50%;
    width: min(96vw, 840px);
    height: 1px;
    transform: translate(-50%, -50%);
    background: linear-gradient(90deg, transparent, rgb(255 209 102 / .7), transparent);
    box-shadow: 0 0 28px rgb(232 59 22 / .55);
    animation: flare-sweep 2.2s .35s cubic-bezier(.16, 1, .3, 1) both;
  }

  .splash__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .splash__logo-shell {
    position: relative;
    width: clamp(180px, 28vw, 290px);
    animation: logo-enter 0.9s 0.14s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .splash__logo {
    position: relative;
    z-index: 1;
    width: 100%;
    height: auto;
    filter: drop-shadow(0 22px 28px rgb(0 0 0 / 0.55))
      drop-shadow(0 0 18px rgb(255 76 20 / 0.28));
    animation: logo-breathe 2.2s 1.05s ease-in-out infinite;
  }
  .splash__ring {
    position: absolute;
    inset: 9%;
    border: 1px solid rgb(255 189 79 / 0.35);
    border-radius: 50%;
    box-shadow:
      0 0 44px rgb(232 59 22 / 0.3),
      inset 0 0 32px rgb(232 59 22 / 0.15);
    animation: ring-expand 1.25s 0.45s ease-out both;
  }

  .splash__eyebrow {
    margin: 1.4rem 0 0.75rem;
    color: #f6c767;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    animation: detail-enter 0.5s 0.8s both;
  }
  .splash__progress {
    width: min(58vw, 220px);
    height: 2px;
    overflow: hidden;
    background: rgb(255 248 237 / 0.14);
    animation: detail-enter 0.5s 0.92s both;
  }
  .splash__progress span {
    display: block;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, #e83b16, #ffd166);
    box-shadow: 0 0 12px #ff5a1f;
    transform-origin: left;
    animation: load 1.55s 0.85s cubic-bezier(0.65, 0, 0.2, 1) both;
  }

  .splash__kicker {
    margin-top: .75rem;
    color: rgb(255 248 237 / .42);
    font-size: .52rem;
    font-weight: 700;
    letter-spacing: .3em;
    text-transform: uppercase;
    animation: detail-enter .5s 1s both;
  }

  @keyframes logo-enter {
    from {
      opacity: 0;
      transform: translateY(22px) scale(0.78);
      filter: blur(8px);
    }
    to {
      opacity: 1;
      transform: none;
      filter: blur(0);
    }
  }
  @keyframes detail-enter {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @keyframes ring-expand {
    from {
      opacity: 0;
      transform: scale(0.55);
    }
    55% {
      opacity: 1;
    }
    to {
      opacity: 0.6;
      transform: scale(1.25);
    }
  }
  @keyframes grill-ignite {
    from {
      opacity: 0;
      transform: scale(0.3);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
  @keyframes halo-pulse {
    50% {
      opacity: 0.72;
      transform: scale(1.07);
    }
  }
  @keyframes embers-rise {
    to {
      background-position:
        0 -72px,
        28px -56px;
    }
  }
  @keyframes load {
    from {
      transform: scaleX(0);
    }
    to {
      transform: scaleX(1);
    }
  }
  @keyframes logo-breathe { 50% { transform: scale(1.025); filter: drop-shadow(0 22px 28px rgb(0 0 0 / .55)) drop-shadow(0 0 30px rgb(255 76 20 / .48)); } }
  @keyframes flare-sweep { from { opacity: 0; transform: translate(-50%, -50%) scaleX(.05); } 35% { opacity: 1; } to { opacity: 0; transform: translate(-50%, -50%) scaleX(1); } }
  @keyframes scan-drift { to { transform: translateY(8px); } }

  @media (prefers-reduced-motion: reduce) {
    .splash {
      display: none;
    }
  }
</style>

<script>
  const splash = document.getElementById("siteSplash");
  const reduceMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (splash && reduceMotion) {
    splash.hidden = true;
  } else if (splash) {
    // Keep the branded moment short enough to feel intentional, never blocking.
    window.setTimeout(() => splash.classList.add("is-leaving"), 2500);
    window.setTimeout(() => {
      splash.hidden = true;
    }, 3200);
  }
</script>
