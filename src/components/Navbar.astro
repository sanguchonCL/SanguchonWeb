---
import logoSanGuchon from "../assets/logo-san-guchon.svg";

const links = [
  { label: "Carta", href: "#especialidades" },
  { label: "El milagro", href: "#anatomia" },
  { label: "Santoral", href: "#santoral" },
  { label: "Feedback", href: "#feedback" },
  { label: "Ubicación", href: "#ubicacion" },
];
---

<header class="fixed inset-x-0 top-0 z-40 pt-3 sm:pt-4">
  <div class="container relative">
    <nav
      id="siteNav"
      class="relative z-50 flex min-h-16 items-center justify-between gap-3 rounded-full border border-line bg-[var(--sg-nav)] px-3 shadow-[0_14px_40px_rgb(20_8_2/.12)] backdrop-blur-xl transition-all duration-300 sm:px-4"
      aria-label="Navegación principal"
    >
      <a
        href="#inicio"
        class="flex shrink-0 items-center gap-2"
        aria-label="Sanguchon, volver al inicio"
      >
        <img
          src={logoSanGuchon.src}
          width="1000"
          height="900"
          alt=""
          class="logo-premium h-11 w-11 object-contain sm:h-12 sm:w-12"
        />
        <span
          class="hidden font-display text-xl leading-none tracking-wide text-ink sm:block"
          >SAN GUCHON<span class="text-fire">.</span></span
        >
      </a>

      <!-- Desktop Menu -->
      <div
        class="hidden items-center gap-6 text-[0.65rem] font-bold uppercase tracking-[0.16em] text-muted md:flex"
      >
        {
          links.map((link) => (
            <a class="transition-colors hover:text-fire" href={link.href}>
              {link.label}
            </a>
          ))
        }
      </div>

      <div class="flex items-center gap-2 sm:gap-3">
        <!-- Mobile Menu Toggle Button -->
        <button
          id="mobileMenuBtn"
          type="button"
          class="grid size-10 shrink-0 place-items-center rounded-full border border-line bg-surface-raised text-ink shadow-sm transition-colors hover:text-fire md:hidden"
          aria-label="Abrir menú"
          aria-expanded="false"
        >
          <svg
            class="menu-icon-open size-[20px]"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M4 6h16M4 12h16M4 18h16"></path></svg
          >
          <svg
            class="menu-icon-close hidden size-[20px]"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"></path></svg
          >
        </button>
      </div>
    </nav>

    <!-- Mobile Menu Dropdown -->
    <div
      id="mobileMenu"
      class="pointer-events-none absolute left-0 right-0 top-full z-40 mt-2 -translate-y-4 opacity-0 transition-all duration-300 md:hidden"
    >
      <div
        class="flex flex-col gap-6 rounded-[1.5rem] border border-line bg-[var(--sg-nav)] p-6 shadow-2xl backdrop-blur-2xl"
      >
        {
          links.map((link) => (
            <a
              class="mobile-menu-link text-xs font-bold uppercase tracking-[0.16em] text-ink transition-colors hover:text-fire"
              href={link.href}
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile Menu Logic
  const mobileMenuBtn = document.getElementById("mobileMenuBtn");
  const mobileMenu = document.getElementById("mobileMenu");
  const mobileMenuLinks = document.querySelectorAll(".mobile-menu-link");
  const iconOpen = mobileMenuBtn?.querySelector(".menu-icon-open");
  const iconClose = mobileMenuBtn?.querySelector(".menu-icon-close");

  function toggleMenu(forceClose = false) {
    if (!mobileMenuBtn || !mobileMenu) return;
    const isExpanded = mobileMenuBtn.getAttribute("aria-expanded") === "true";

    if (isExpanded || forceClose) {
      mobileMenuBtn.setAttribute("aria-expanded", "false");
      mobileMenu.classList.remove(
        "opacity-100",
        "translate-y-0",
        "pointer-events-auto",
      );
      mobileMenu.classList.add(
        "opacity-0",
        "-translate-y-4",
        "pointer-events-none",
      );
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    } else {
      mobileMenuBtn.setAttribute("aria-expanded", "true");
      mobileMenu.classList.remove(
        "opacity-0",
        "-translate-y-4",
        "pointer-events-none",
      );
      mobileMenu.classList.add(
        "opacity-100",
        "translate-y-0",
        "pointer-events-auto",
      );
      iconOpen?.classList.add("hidden");
      iconClose?.classList.remove("hidden");
    }
  }

  mobileMenuBtn?.addEventListener("click", () => toggleMenu());

  mobileMenuLinks.forEach((link) => {
    link.addEventListener("click", () => toggleMenu(true));
  });

  const siteNav = document.getElementById("siteNav");
  const syncScrolledNav = () =>
    siteNav?.classList.toggle("nav-is-scrolled", window.scrollY > 28);
  syncScrolledNav();
  window.addEventListener("scroll", syncScrolledNav, { passive: true });
</script>

<style>
  #siteNav.nav-is-scrolled {
    box-shadow: 0 16px 44px rgb(20 8 2 / 0.2);
    transform: scale(0.985);
  }
</style>
