---
import { menuItems } from '../../data/menu';
---

<section id="especialidades" class="menu" style="background:var(--cream-warm)">
  <div class="container">
    <div class="section-header reveal">
      <span class="chip chip--dark">
        <span class="material-symbols-rounded chip__icon">lunch_dining</span> Especialidades
      </span>
      <h2>Sabores que <span class="font-display text-red">Enamoran</span></h2>
      <p class="section-header__sub">Cada plato es una historia. Descubre por qué somos la hamburguesa más pedida de San Miguel.</p>
    </div>

    <div class="menu__grid">
      {menuItems.map((item) => (
        <article class={`menu-card reveal delay-${item.id}`}>
          <div class="menu-card__img">
            <div class="menu-card__img-placeholder">
              <span class="material-symbols-rounded">lunch_dining</span>
            </div>
            {item.badge && <span class="menu-card__badge">{item.badge}</span>}
          </div>
          <div class="menu-card__body">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- Wave -->
<svg class="wave-separator" viewBox="0 0 1440 100" preserveAspectRatio="none" style="background:var(--cream-warm)">
  <path fill="var(--cream)" d="M0,40 C360,100 720,0 1440,60 L1440,100 L0,100Z" />
</svg>

<style>
  .menu__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .menu-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(60, 30, 10, 0.04), 0 1px 3px rgba(60, 30, 10, 0.02);
    transition: all var(--duration) var(--ease-out);
    border: 1px solid rgba(212, 168, 85, 0.16);
    display: flex; flex-direction: column;
    position: relative;
  }
  .menu-card::after {
    content: ''; position: absolute; inset: 0; border-radius: var(--radius-lg);
    border: 2px solid transparent; transition: all var(--duration) var(--ease-out); pointer-events: none;
  }
  .menu-card:hover {
    transform: translateY(-8px) scale(1.005);
    box-shadow: 0 25px 50px rgba(60, 30, 10, 0.08), 0 0 15px rgba(249, 168, 37, 0.1);
    border-color: rgba(249, 168, 37, 0.3);
  }
  .menu-card:hover::after { border-color: rgba(249, 168, 37, 0.15); }

  .menu-card__img {
    position: relative; height: 250px; overflow: hidden;
    mask-image: linear-gradient(to bottom, black 95%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 95%, transparent 100%);
  }

  .menu-card__img-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, var(--cream-warm) 0%, var(--tan) 50%, var(--mustard) 100%);
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.8s var(--ease-out);
  }
  .menu-card__img-placeholder .material-symbols-rounded {
    font-size: 4rem; color: rgba(255,255,255,0.5);
    font-variation-settings: 'FILL' 1, 'wght' 200;
  }
  .menu-card:hover .menu-card__img-placeholder { transform: scale(1.04) rotate(0.5deg); }

  .menu-card__badge {
    position: absolute; top: 1.2rem; left: 1.2rem;
    padding: 0.45rem 1rem;
    background: linear-gradient(135deg, var(--ketchup) 0%, var(--red-light) 100%);
    color: var(--text-white);
    border-radius: var(--radius-full);
    font-size: 0.8rem; font-weight: 800;
    box-shadow: 0 4px 15px rgba(198, 40, 40, 0.45);
    letter-spacing: 0.02em; text-transform: uppercase;
  }

  .menu-card__body {
    padding: 2.2rem 2rem;
    display: flex; flex-direction: column; flex: 1;
    background: linear-gradient(180deg, var(--white) 0%, rgba(254, 245, 231, 0.25) 100%);
  }
  .menu-card__body h3 {
    margin-bottom: 0.7rem; font-size: 1.45rem; font-weight: 800;
    color: var(--text-dark); transition: color 0.3s ease;
  }
  .menu-card:hover .menu-card__body h3 { color: var(--ketchup); }
  .menu-card__body p {
    color: var(--text-body); font-size: 0.94rem;
    flex: 1; line-height: 1.6;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .menu__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .menu__grid { grid-template-columns: 1fr; gap: 1.2rem; }

    .menu-card { flex-direction: row; align-items: stretch; }

    .menu-card__img {
      width: 130px; height: auto; min-height: 140px; flex-shrink: 0;
      mask-image: linear-gradient(to right, black 70%, transparent 100%);
      -webkit-mask-image: linear-gradient(to right, black 70%, transparent 100%);
    }

    .menu-card__badge {
      top: 0.5rem; left: 0.5rem;
      padding: 0.25rem 0.6rem; font-size: 0.65rem;
      white-space: pre-wrap; text-align: center; line-height: 1.1;
    }

    .menu-card__body {
      padding: 1.2rem 1rem 1.2rem 0; justify-content: center;
    }
    .menu-card__body h3 { font-size: 1.15rem; margin-bottom: 0.4rem; }
    .menu-card__body p { font-size: 0.88rem; }
  }
</style>
