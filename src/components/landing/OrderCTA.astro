<section class="cta-banner">
  <div class="container cta-banner__inner reveal">
    <div class="cta-banner__text">
      <h2>¿Listo para Probar <span class="font-display">lo Mejor de San Miguel</span>?</h2>
      <p>Visítanos en San Nicolás 1390, pide por delivery o contáctanos. ¡Te esperamos con la parrilla encendida!</p>
    </div>
    <div class="cta-banner__actions">
      <a href="#feedback" class="btn btn-outline-light btn-lg">
        <span class="material-symbols-rounded">chat_bubble</span> Escríbenos
      </a>
      <a href="#ubicacion" class="btn btn-secondary btn-lg">
        <span class="material-symbols-rounded">directions</span> Visítanos
      </a>
    </div>
  </div>
</section>

<style>
  .cta-banner {
    background: linear-gradient(135deg, rgba(90, 16, 16, 0.92) 0%, rgba(142, 27, 27, 0.85) 30%, rgba(198, 40, 40, 0.8) 60%, rgba(230, 168, 23, 0.85) 100%),
                url('/images/local_noche.webp') center/cover no-repeat fixed;
    padding-block: var(--section-py);
    position: relative; overflow: hidden;
  }

  .cta-banner::before {
    content: ''; position: absolute; inset: 0; opacity: 0.05;
    background-image: radial-gradient(var(--sesame) 1px, transparent 1px);
    background-size: 24px 24px;
  }

  .cta-banner::after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0;
    height: 120px;
    background: linear-gradient(to top, rgba(0,0,0,0.15), transparent);
  }

  .cta-banner__inner {
    display: flex; justify-content: space-between; align-items: center;
    gap: 3rem; position: relative; z-index: 1;
  }

  .cta-banner__text h2 {
    color: var(--text-white);
    font-size: clamp(1.8rem, 3vw, 2.5rem);
  }
  .cta-banner__text p {
    color: rgba(255,250,245,0.88);
    margin-top: 0.5rem; max-width: 480px;
  }

  .cta-banner__actions {
    display: flex; gap: 1rem; flex-shrink: 0;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .cta-banner__inner { flex-direction: column; text-align: center; }
    .cta-banner__text p { margin-inline: auto; }
    .cta-banner__actions { justify-content: center; flex-wrap: wrap; }
  }

  @media (max-width: 768px) {
    .cta-banner__actions { flex-direction: column; width: 100%; gap: 1rem; }
    .cta-banner__actions .btn { width: 100%; }
  }
</style>
