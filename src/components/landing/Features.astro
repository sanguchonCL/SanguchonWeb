---
import { features } from '../../data/menu';
---

<section id="porqueelegirnos" class="features">
  <div class="features__glow-top"></div>
  <div class="container">
    <div class="section-header section-header--light reveal">
      <span class="chip">
        <span class="material-symbols-rounded chip__icon">emoji_events</span> Lo Que Nos Hace Únicos
      </span>
      <h2 class="text-white-heading">¿Por Qué <span class="font-display text-gold">Elegirnos</span>?</h2>
      <p class="section-header__sub--light">No es solo comida. Es lo que hace que San Miguel tenga su propia leyenda gastronómica.</p>
    </div>

    <div class="features__grid">
      {features.map((f) => (
        <div class={`feature-card reveal delay-${f.id}`}>
          <div class="feature-card__icon-wrap">
            <span class="material-symbols-rounded">{f.icon}</span>
          </div>
          <div class="feature-card__content">
            <h4>{f.title}</h4>
            <p>{f.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    position: relative; overflow: hidden;
    background-image: radial-gradient(circle at 50% 0%, rgba(198, 40, 40, 0.15), transparent 50%),
                      radial-gradient(circle at 10% 90%, rgba(249, 168, 37, 0.08), transparent 40%),
                      linear-gradient(180deg, var(--charcoal) 0%, var(--dark) 40%, var(--dark-card) 100%);
  }

  .features__glow-top {
    position: absolute; top: 0; left: 50%;
    transform: translateX(-50%);
    width: 700px; height: 4px;
    background: linear-gradient(90deg, transparent, var(--mustard), var(--ketchup), var(--cheese), var(--mustard), transparent);
    border-radius: 4px;
  }

  .features__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem; margin-top: 3rem;
  }

  .feature-card {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    padding: 2rem 1.5rem;
    cursor: pointer;
    transition: all var(--duration) var(--ease-out);
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    background: linear-gradient(135deg, rgba(42,29,23,0.9) 0%, rgba(28,18,16,0.95) 100%);
    display: flex; flex-direction: column; gap: 1.2rem;
    min-height: 280px;
  }

  .feature-card::after {
    content: ''; position: absolute; inset: 0; border-radius: var(--radius-lg);
    border: 1px solid rgba(212, 168, 85, 0.12); pointer-events: none;
    transition: border var(--duration) var(--ease-out);
  }

  .feature-card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5), 0 0 25px rgba(249, 168, 37, 0.2);
    border-color: rgba(249, 168, 37, 0.3);
  }
  .feature-card:hover::after { border-color: rgba(249, 168, 37, 0.3); }

  .feature-card__icon-wrap {
    width: 52px; height: 52px;
    border-radius: var(--radius-sm);
    background: linear-gradient(135deg, var(--ketchup), var(--mustard));
    display: flex; align-items: center; justify-content: center;
    color: var(--text-white);
    box-shadow: 0 4px 16px rgba(198,40,40,0.3);
    transition: all 0.4s var(--ease-spring);
  }
  .feature-card:hover .feature-card__icon-wrap {
    transform: scale(1.1) rotate(-5deg);
    box-shadow: 0 8px 24px rgba(198,40,40,0.4);
  }
  .feature-card__icon-wrap .material-symbols-rounded { font-size: 1.6rem; }

  .feature-card__content h4 {
    color: var(--text-white); font-size: 1.2rem; margin-bottom: 0.5rem;
  }
  .feature-card__content p {
    color: rgba(255,250,245,0.65); font-size: 0.88rem;
    line-height: 1.6; opacity: 0.85;
    transition: opacity 0.4s ease;
  }
  .feature-card:hover .feature-card__content p { opacity: 1; color: rgba(255,250,245,0.85); }

  /* Responsive */
  @media (max-width: 1024px) {
    .features__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .features__grid { grid-template-columns: 1fr 1fr; gap: 1rem; }
    .feature-card { min-height: 220px; padding: 1.5rem 1.2rem; }
    .feature-card__icon-wrap { width: 40px; height: 40px; }
    .feature-card__icon-wrap .material-symbols-rounded { font-size: 1.2rem; }
    .feature-card__content h4 { font-size: 1rem; }
  }
</style>
