---
import logoSanGuchon from "../../assets/logo-san-guchon.svg";
---

<section
  id="inicio"
  class="relative isolate flex min-h-svh items-center overflow-hidden bg-canvas pb-16 pt-28 sm:pb-12 sm:pt-32"
>
  <div class="hero-atmosphere absolute inset-0" aria-hidden="true"></div>
  <div
    class="pointer-events-none absolute -right-24 top-32 size-72 rounded-full bg-fire/10 blur-3xl sm:size-[32rem]"
    aria-hidden="true"
  >
  </div>
  <span
    class="pointer-events-none absolute -right-16 top-1/2 hidden -translate-y-1/2 rotate-90 font-display text-[12rem] leading-none text-ink/[.025] xl:block"
    >SANGUCHON</span
  >

  <div
    class="container relative grid items-center gap-4 lg:grid-cols-[.9fr_1.1fr] lg:gap-8"
  >
    <div class="relative z-10 pb-2 lg:pb-0">
      <div class="mb-4 flex items-center gap-3 sm:mb-6">
        <p
          class="flex items-center gap-2 text-[0.62rem] font-bold uppercase tracking-[0.2em] text-muted"
        >
          <span
            class="size-1.5 rounded-full bg-fire shadow-[0_0_14px_3px_rgb(232_59_22/.45)]"
          ></span> San Miguel, Santiago
        </p>
      </div>

      <h1
        class="max-w-3xl font-display text-[clamp(4.2rem,10vw,10.5rem)] leading-[.78] tracking-[-0.045em] text-ink"
      >
        <span class="block animate-[fade-in_.6s_ease-out_both]">EL SABOR</span>
        <span class="block text-fire">SAGRADO</span>
        <span class="block">HA LLEGADO</span>
      </h1>

      <p class="mt-6 max-w-sm text-sm leading-relaxed text-ink-soft sm:mt-8">
        Hamburguesas hechas a la plancha y servidas con hambre real.
      </p>
      <div class="mt-6 flex flex-wrap items-center gap-4 sm:mt-8">
        <a
          href="/menu-san-guchon.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-fire px-6 py-3 text-xs font-bold uppercase tracking-[.16em] text-white shadow-[0_12px_28px_rgb(232_59_22/.28)] transition hover:-translate-y-1 hover:bg-fire-bright"
        >
          Ver la carta
          <svg
            class="size-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"></path></svg
          >
        </a>
        <a
          href="#anatomia"
          class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[.16em] text-muted transition-colors hover:text-fire"
          >Conoce el ritual <span aria-hidden="true">↓</span></a
        >
      </div>
    </div>

    <div
      class="relative mx-auto -mt-2 w-full max-w-2xl sm:mt-0 lg:translate-y-8"
    >
      <div
        class="absolute inset-[14%] rounded-full bg-fire/15 blur-3xl"
        aria-hidden="true"
      >
      </div>
      <div
        class="pointer-events-none absolute left-[4%] top-[18%] hidden size-20 rounded-full border border-fire/30 sm:block sm:size-28"
        aria-hidden="true"
      >
        <span
          class="absolute -right-1 top-1/2 size-2 rounded-full bg-cheese shadow-[0_0_12px_3px_rgb(255_209_102/.7)]"
        ></span>
      </div>
      <div
        class="float-slow absolute left-0 top-1/2 z-20 hidden -translate-y-1/2 rounded-full border border-line bg-[var(--sg-nav)] px-3 py-2 text-[0.56rem] font-bold uppercase tracking-[.14em] text-ink shadow-xl backdrop-blur-md sm:block"
      >
        Plancha<br /><span class="text-fire">a fuego alto</span>
      </div>
      <img
        src="/images/products/burger-hero.webp"
        width="1024"
        height="1024"
        alt="Hamburguesa artesanal Sanguchon"
        class="relative z-10 mx-auto w-full animate-float object-contain saturate-[1.06] contrast-[1.04] drop-shadow-[0_30px_30px_rgb(23_7_2/.45)]"
        fetchpriority="high"
      />
      <div
        class="float-slow absolute bottom-[15%] right-0 z-20 rounded-full border border-line bg-[var(--sg-nav)] px-3 py-2 text-[0.56rem] font-bold uppercase tracking-[.14em] text-ink shadow-xl backdrop-blur-md"
      >
        100% Angus<br /><span class="text-fire">sin atajos</span>
      </div>
      <p
        class="absolute bottom-2 right-0 z-20 hidden text-right text-[0.6rem] font-bold uppercase tracking-[.18em] text-muted sm:block"
      >
        Fuego real<br />desde 2026
      </p>
    </div>
  </div>

  <div
    class="absolute bottom-0 left-0 w-full overflow-hidden border-y border-charcoal bg-cheese py-2 text-charcoal"
    aria-label="Sanguchon, fuego real, San Miguel, sanguchería de culto"
  >
    <div
      class="flex w-max animate-marquee whitespace-nowrap font-display text-xl tracking-wide"
    >
      <span
        >SANGUCHON ✦ FUEGO REAL ✦ SAN MIGUEL ✦ SANGUCHERÍA DE CULTO ✦&nbsp;</span
      ><span
        >SANGUCHON ✦ FUEGO REAL ✦ SAN MIGUEL ✦ SANGUCHERÍA DE CULTO ✦&nbsp;</span
      >
    </div>
  </div>
</section>
