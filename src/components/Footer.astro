---
import { SITE_INFO } from "../data/site-info";
import logoSanGuchon from "../assets/logo-san-guchon.svg";
---

<footer
  id="contacto"
  class="overflow-hidden border-t border-white/10 bg-charcoal pt-0 text-white"
>
  <div class="border-y border-charcoal bg-cheese py-2 text-charcoal">
    <div
      class="flex w-max animate-marquee whitespace-nowrap font-display text-xl tracking-wide"
    >
      <span
        >SAN GUCHON ✦ FUEGO REAL ✦ SAN MIGUEL ✦ SANGUCHERÍA DE CULTO ✦&nbsp;</span
      ><span
        >SAN GUCHON ✦ FUEGO REAL ✦ SAN MIGUEL ✦ SANGUCHERÍA DE CULTO ✦&nbsp;</span
      >
    </div>
  </div>

  <div class="container grid gap-12 py-16 md:grid-cols-[1.4fr_.6fr_.8fr]">
    <div>
      <a href="#inicio" class="flex w-fit items-center gap-4">
        <img
          src={logoSanGuchon.src}
          width="1000"
          height="900"
          alt=""
          class="logo-premium size-20 object-contain"
        />
        <span class="font-display text-5xl leading-[.8] tracking-[-.03em]"
          >SAN GUCHON</span
        >
      </a>
      <p class="mt-6 max-w-sm text-sm leading-relaxed text-white/50">
        Sanguchería. Fuego real, hambre real y ninguna excusa para comer
        aburrido.
      </p>
    </div>

    <nav aria-label="Navegación del pie de página">
      <p
        class="mb-5 text-[0.65rem] font-bold uppercase tracking-[.2em] text-white/40"
      >
        Navega
      </p>
      <div class="flex flex-col gap-3 text-sm text-white/75">
        <a href="#especialidades" class="hover:text-cheese">Best sellers</a><a
          href="#anatomia"
          class="hover:text-cheese">El milagro</a
        ><a href="#santoral" class="hover:text-cheese">Santoral</a><a
          href="#feedback"
          class="hover:text-cheese">Feedback</a
        ><a href="#ubicacion" class="hover:text-cheese">Ubicación</a><a
          href={SITE_INFO.menuUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-cheese">Carta completa ↗</a
        >
      </div>
    </nav>

    <div>
      <p
        class="mb-5 text-[0.65rem] font-bold uppercase tracking-[.2em] text-white/40"
      >
        Contacto
      </p>
      <a
        href={SITE_INFO.instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-white/75 transition-colors hover:text-cheese"
        aria-label="Seguir a Sanguchon en Instagram"
      >
        <svg
          class="size-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          aria-hidden="true"
          ><rect x="3" y="3" width="18" height="18" rx="5"></rect><circle
            cx="12"
            cy="12"
            r="4"></circle><circle
            cx="17.5"
            cy="6.5"
            r=".8"
            fill="currentColor"
            stroke="none"></circle></svg
        >
        @sanguchoncl
      </a>
      <p class="mt-4 text-sm leading-relaxed text-white/45">
        {SITE_INFO.schedule}
      </p>
    </div>
  </div>

  <div
    class="container flex flex-col items-center gap-4 border-t border-white/10 py-6 text-[0.65rem] font-bold uppercase tracking-[.14em] text-white/40 sm:flex-row sm:items-center sm:justify-between"
  >
    <span>© 2026 Sanguchon</span>
    <a
      href={SITE_INFO.linkedinUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="rounded-full border border-zinc-700 px-3 py-2 text-xs font-medium normal-case tracking-normal text-zinc-400 transition-colors hover:border-cheese hover:text-cheese"
      >Diseñado y desarrollado por Jorge Vergara</a
    >
  </div>
</footer>
